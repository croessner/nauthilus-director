COMPOSE_PROJECT_NAME=nauthilus-director-demo

DEMO_PASSWORD=demo-secret

SMTP_PORT=2525
IMAP_PORT=8143
IMAPS_PORT=8993
LMTPS_PORT=8024
HAPROXY_STATS_PORT=8404
DIRECTOR_A_CONTROL_PORT=9090
DIRECTOR_B_CONTROL_PORT=9091

VALKEY_IMAGE=valkey/valkey:9.1.0-alpine
DOVECOT_IMAGE=dovecot/dovecot:2.4.4
NAUTHILUS_IMAGE=ghcr.io/croessner/nauthilus:v3.0.0-rc.4
POSTFIX_IMAGE=chrroessner/postfix:3.11.3
OPENLDAP_IMAGE=chrroessner/openldap:2.6.13
HAPROXY_IMAGE=haproxy:3.2-alpine
